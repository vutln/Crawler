# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# --- Database (MySQL 8.0.32) ---
# Prisma 7 requires a driver adapter; we parse this URL and hand it to @prisma/adapter-mariadb.
DATABASE_URL="mysql://crawler:CHANGE_ME@localhost:3306/crawler"
# Used only by `npm test` (integration tier). Separate schema keeps test data off your dev data.
TEST_DATABASE_URL="mysql://crawler:CHANGE_ME@localhost:3306/crawler_test"

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Selenium ---
# false = watch the browser work (useful when writing a new adapter)
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT_MS=30000
SELENIUM_MAX_DRIVERS=2

# --- Politeness ---
# Be conservative. These defaults keep the collector inside acceptable-use limits.
CRAWL_MIN_DELAY_MS=2000
CRAWL_MAX_RETRIES=3
CRAWL_MAX_BACKOFF_MS=900000
CRAWL_RESPECT_ROBOTS=true
# Empty means Chrome sends its own native browser user-agent.
CRAWL_USER_AGENT=

# --- Optional official APIs ---
# When set, the adapter registry prefers the API adapter over the Selenium one
# for that marketplace: same interface, dramatically more reliable.
# eBay Browse API:  https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=
# Etsy Open API v3: https://developers.etsy.com/
ETSY_API_KEY=

# Usually unnecessary because Chrome already sends normal browser headers.
# Only include headers specifically required by the target site.
CRAWL_EXTRA_HEADERS_JSON={}

# Non-sensitive preference cookies, applied via CDP before the first request.
# NEVER put authenticated session cookies here.
#
# LOAD-BEARING — do not empty this. i18n-prefs is what makes Amazon report US
# prices. amazon.com is the US store, but it converts the display currency to the
# visitor's geolocated country: from a Vietnam IP a $12.99 shirt renders as
# "₫330.000", and the USD price is present only in embedded JSON the parser never
# reads. This cookie tells Amazon to show the USD it already has.
#
# Measured on 2026-07-17 — same code, same IP, same URL, cookie the only variable:
#   without CRAWL_COOKIES_JSON  ->  48 cards, prices in VND
#   with    CRAWL_COOKIES_JSON  ->  48 cards, prices in USD
#
# Shipping this empty is how a fresh clone silently collects the wrong market.
# test/canary/amazon-currency.canary-spec.ts guards the mechanism; run it if
# Amazon prices ever come back non-USD.
CRAWL_COOKIES_JSON=[{"name":"i18n-prefs","value":"USD","domain":".amazon.com","path":"/"},{"name":"lc-main","value":"en_US","domain":".amazon.com","path":"/"}]

# US ZIP to set as the browser's delivery address. Empty = don't set one.
#
# The other half of the US-market requirement, and the half the cookie above
# cannot do. i18n-prefs fixes the CURRENCY; this fixes AVAILABILITY. Amazon hides
# the price outright on any listing it can't ship to the session's address, and
# with no address it infers one from the egress IP — so from Vietnam a share of
# listings come back with title, rating and review count but price: null and
# currency: XXX. Naming a US ZIP is what makes those prices exist at all.
#
# Not a cookie, which is why it isn't in CRAWL_COOKIES_JSON: Amazon keeps the
# address server-side against the session, so AmazonSeleniumAdapter sets it
# through the site's own location widget once per browser. That costs one extra
# page load per crawl — the reason it's optional rather than hardcoded.
#
# 00501 is Holtsville, NY: a real, ordinary US delivery ZIP. Any US ZIP works;
# they differ in shipping estimates and local availability, not in currency.
AMAZON_DELIVERY_ZIP=00501
