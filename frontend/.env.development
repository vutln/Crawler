# Empty on purpose. Requests go to relative /api/* and Vite proxies them to the
# backend, which keeps everything same-origin in dev. Setting an absolute URL
# here would re-introduce CORS.
VITE_API_BASE_URL=
VITE_ENABLE_DEVTOOLS=true

# Consumed by vite.config.ts only (no VITE_ prefix => never reaches the bundle).
BACKEND_URL=http://localhost:3000
