# Copy to .env and fill in. .env is gitignored — never commit real credentials.

# --- Database (MySQL 8.0.32) ---
# Prisma 7 requires a driver adapter; we parse this URL and hand it to @prisma/adapter-mariadb.
DATABASE_URL="mysql://crawler:CHANGE_ME@localhost:3306/crawler"
# Used only by `npm test` (integration tier). Separate schema keeps test data off your dev data.
TEST_DATABASE_URL="mysql://crawler:CHANGE_ME@localhost:3306/crawler_test"

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Selenium ---
# false = watch the browser work (useful when writing a new adapter)
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT_MS=30000
SELENIUM_MAX_DRIVERS=2

# --- Politeness ---
# Be conservative. These defaults keep the collector inside acceptable-use limits.
CRAWL_MIN_DELAY_MS=2000
CRAWL_MAX_RETRIES=3
CRAWL_MAX_BACKOFF_MS=900000
CRAWL_RESPECT_ROBOTS=true
# Empty means Chrome sends its own native browser user-agent.
CRAWL_USER_AGENT=

# --- Optional official APIs ---
# When set, the adapter registry prefers the API adapter over the Selenium one
# for that marketplace: same interface, dramatically more reliable.
# eBay Browse API:  https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=
# Etsy Open API v3: https://developers.etsy.com/
ETSY_API_KEY=

# Usually unnecessary because Chrome already sends normal browser headers.
# Only include headers specifically required by the target site.
CRAWL_EXTRA_HEADERS_JSON={}

# Optional non-sensitive preference or consent cookies.
# Do not commit authenticated session cookies.
CRAWL_COOKIES_JSON=[]
